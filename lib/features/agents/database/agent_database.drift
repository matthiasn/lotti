-- Agent domain database schema (agent.sqlite)
-- Separate from journal domain (db.sqlite)

CREATE TABLE agent_entities (
  id TEXT NOT NULL PRIMARY KEY,
  agent_id TEXT NOT NULL,
  type TEXT NOT NULL,
  subtype TEXT,
  thread_id TEXT,
  created_at DATETIME NOT NULL,
  updated_at DATETIME NOT NULL,
  deleted_at DATETIME,
  serialized TEXT NOT NULL,
  schema_version INTEGER NOT NULL DEFAULT 1
);

CREATE INDEX idx_agent_entities_agent_id ON agent_entities(agent_id);
CREATE INDEX idx_agent_entities_type ON agent_entities(type, agent_id, created_at DESC);
CREATE INDEX idx_agent_entities_agent_type_sub ON agent_entities(agent_id, type, subtype, created_at DESC);
CREATE INDEX idx_agent_entities_thread ON agent_entities(agent_id, thread_id, created_at DESC);
-- Supports `_latestEntitiesByAgentIds`, which ranks each active
-- agent/type partition by `(created_at DESC, id DESC)`. Without the
-- `id` tie-breaker in the index, SQLite logs this hot batch path as
-- `USE TEMP B-TREE FOR LAST TERM OF ORDER BY`.
CREATE INDEX idx_agent_entities_active_agent_type_created_id ON agent_entities(agent_id, type, created_at DESC, id DESC) WHERE deleted_at IS NULL;
CREATE INDEX idx_agent_entities_active_agent_type_sub_created_id ON agent_entities(agent_id, type, subtype, created_at DESC, id DESC) WHERE deleted_at IS NULL;
CREATE INDEX idx_agent_entities_active_type_created ON agent_entities(type, created_at DESC) WHERE deleted_at IS NULL;
CREATE INDEX idx_agent_entities_active_type_sub_created_id ON agent_entities(type, subtype, created_at DESC, id DESC) WHERE deleted_at IS NULL;
CREATE INDEX idx_agent_entities_token_usage_since ON agent_entities(type, created_at DESC) WHERE type = 'wakeTokenUsage' AND deleted_at IS NULL;
-- Expression partial for `getDueScheduledAgentStates`. The query
-- filters `type = 'agentState' AND deleted_at IS NULL AND
-- json_extract(serialized, '$.scheduledWakeAt') <= :nowIso` and used
-- to fall back to `idx_agent_entities_type` followed by a per-row
-- heap probe to evaluate the JSON predicate, which dominated the
-- agent.sqlite slow-query bucket. Indexing the extracted value
-- directly turns the wake probe into an index range scan over the
-- (small) set of agent-state rows that have a scheduled wake time.
CREATE INDEX idx_agent_entities_due_wake ON agent_entities(
  json_extract(serialized, '$.scheduledWakeAt') ASC
)
WHERE type = 'agentState'
  AND deleted_at IS NULL
  AND json_extract(serialized, '$.scheduledWakeAt') IS NOT NULL;

CREATE TABLE agent_links (
  id TEXT NOT NULL PRIMARY KEY,
  from_id TEXT NOT NULL,
  to_id TEXT NOT NULL,
  type TEXT NOT NULL,
  created_at DATETIME NOT NULL,
  updated_at DATETIME NOT NULL,
  deleted_at DATETIME,
  serialized TEXT NOT NULL,
  schema_version INTEGER NOT NULL DEFAULT 1
);

CREATE INDEX idx_agent_links_from ON agent_links(from_id, type);
CREATE INDEX idx_agent_links_to ON agent_links(to_id, type);
CREATE INDEX idx_agent_links_type ON agent_links(type);
-- (from_id, to_id, type) stays unique for assignment-style links and DAG
-- edges, but NOT for `message_payload` capture events (ADR 0020): content
-- addressing dedupes identical content into one shared payload, so two
-- sources rendering the same bytes each keep their own link (provenance +
-- event position) to the SAME digest — and an entry edited back to earlier
-- content appends a new event for an already-linked digest. The previous
-- table-level UNIQUE made both cases fail capture with SqliteException 2067.
CREATE UNIQUE INDEX idx_agent_links_unique_from_to_type
  ON agent_links(from_id, to_id, type) WHERE type != 'message_payload';
CREATE UNIQUE INDEX idx_unique_improver_per_template ON agent_links(to_id) WHERE type = 'improver_target' AND deleted_at IS NULL;
CREATE UNIQUE INDEX idx_unique_soul_per_template ON agent_links(from_id) WHERE type = 'soul_assignment' AND deleted_at IS NULL;
CREATE INDEX idx_agent_links_active_from_type_to ON agent_links(from_id, type, to_id) WHERE deleted_at IS NULL;
CREATE INDEX idx_agent_links_active_to_type ON agent_links(to_id, type) WHERE deleted_at IS NULL;

CREATE TABLE attention_claim_index (
  request_id TEXT NOT NULL PRIMARY KEY,
  agent_id TEXT NOT NULL,
  status TEXT NOT NULL,
  scope_kind TEXT NOT NULL,
  visibility_start DATETIME NOT NULL,
  visibility_end DATETIME NOT NULL,
  deadline DATETIME,
  next_review_at DATETIME,
  target_id TEXT,
  target_kind TEXT,
  updated_at DATETIME NOT NULL,
  deleted_at DATETIME
);

CREATE INDEX idx_attention_claims_active_window
  ON attention_claim_index(status, visibility_start, visibility_end, next_review_at, deadline, request_id)
  WHERE deleted_at IS NULL;
CREATE INDEX idx_attention_claims_active_deadline
  ON attention_claim_index(status, deadline, request_id)
  WHERE deleted_at IS NULL AND deadline IS NOT NULL;
CREATE INDEX idx_attention_claims_active_target
  ON attention_claim_index(target_kind, target_id, status, updated_at DESC, request_id)
  WHERE deleted_at IS NULL AND target_kind IS NOT NULL AND target_id IS NOT NULL;

CREATE TABLE standing_agreement_index (
  agreement_id TEXT NOT NULL PRIMARY KEY,
  agent_id TEXT NOT NULL,
  status TEXT NOT NULL,
  scope TEXT NOT NULL,
  cadence TEXT NOT NULL,
  approval_mode TEXT NOT NULL,
  enforcement TEXT NOT NULL,
  active_from DATETIME NOT NULL,
  active_until DATETIME NOT NULL,
  priority INTEGER NOT NULL,
  target_id TEXT,
  target_kind TEXT,
  updated_at DATETIME NOT NULL,
  deleted_at DATETIME
);

CREATE INDEX idx_standing_agreements_active_window
  ON standing_agreement_index(status, active_from, active_until, priority DESC, updated_at DESC, agreement_id)
  WHERE deleted_at IS NULL;
CREATE INDEX idx_standing_agreements_active_scope_window
  ON standing_agreement_index(status, scope, active_from, active_until, priority DESC, updated_at DESC, agreement_id)
  WHERE deleted_at IS NULL;

CREATE TABLE wake_run_log (
  run_key TEXT NOT NULL PRIMARY KEY,
  agent_id TEXT NOT NULL,
  reason TEXT NOT NULL,
  reason_id TEXT,
  thread_id TEXT NOT NULL,
  status TEXT NOT NULL,
  logical_change_key TEXT,
  created_at DATETIME NOT NULL,
  started_at DATETIME,
  completed_at DATETIME,
  error_message TEXT,
  template_id TEXT,
  template_version_id TEXT,
  resolved_model_id TEXT,
  soul_id TEXT,
  soul_version_id TEXT,
  user_rating REAL,
  rated_at DATETIME
);

CREATE INDEX idx_wake_run_log_agent ON wake_run_log(agent_id, created_at DESC);
CREATE INDEX idx_wake_run_log_template ON wake_run_log(template_id, created_at DESC);
CREATE INDEX idx_wake_run_log_status ON wake_run_log(status);
CREATE INDEX idx_wake_run_log_agent_thread ON wake_run_log(agent_id, thread_id, created_at DESC);
-- `getWakeRunsInWindow` filters on `created_at >= ? AND created_at <= ?`
-- and orders by `created_at DESC`. The existing indices above are all
-- leaded by `agent_id`, `template_id`, or `status` — none lets the
-- planner walk by `created_at`. The 2026-05-10 desktop super_slow log
-- captured this as `SCAN wake_run_log` + `USE TEMP B-TREE FOR ORDER BY`
-- at 305 ms / 408 ms (11 hits). A `created_at`-only index turns the
-- range query into an in-order index walk and lets the LIMIT walk
-- stop without a sort step.
CREATE INDEX idx_wake_run_log_created_at ON wake_run_log(created_at DESC);

CREATE TABLE saga_log (
  operation_id TEXT NOT NULL PRIMARY KEY,
  agent_id TEXT NOT NULL,
  run_key TEXT NOT NULL,
  phase TEXT NOT NULL,
  status TEXT NOT NULL,
  tool_name TEXT NOT NULL,
  last_error TEXT,
  created_at DATETIME NOT NULL,
  updated_at DATETIME NOT NULL
);

CREATE INDEX idx_saga_log_agent ON saga_log(agent_id);
CREATE INDEX idx_saga_log_status ON saga_log(status, updated_at);
CREATE INDEX idx_saga_log_status_created_at ON saga_log(status, created_at ASC);

-- Named queries

getAgentEntitiesByAgentId: SELECT * FROM agent_entities WHERE agent_id = :agentId AND deleted_at IS NULL ORDER BY created_at DESC LIMIT :limit;

getAgentEntitiesByType: SELECT * FROM agent_entities WHERE agent_id = :agentId AND type = :type AND deleted_at IS NULL ORDER BY created_at DESC LIMIT :limit;

getAgentEntitiesByTypeAndSubtype: SELECT * FROM agent_entities WHERE agent_id = :agentId AND type = :type AND subtype = :subtype AND deleted_at IS NULL ORDER BY created_at DESC LIMIT :limit;

getAgentEntityById: SELECT * FROM agent_entities WHERE id = :id AND deleted_at IS NULL;

-- Narrow projection used by the sync attachment ingestor's
-- VC-dominance check. SELECT * of this row was costing ~36ms avg
-- (p95=101ms, max=239ms) because it deserialized the full serialized
-- JSON blob just to read a nested field. Returning the extracted
-- vector_clock alone keeps the read on the id index and lets us
-- decide whether to skip an already-covered download without ever
-- touching the big payload column.
getAgentEntityVectorClockById:
  SELECT json_extract(serialized, '$.vectorClock') AS vector_clock
  FROM agent_entities
  WHERE id = :id AND deleted_at IS NULL;

getAgentMessagesByThread: SELECT * FROM agent_entities WHERE agent_id = :agentId AND type = 'agentMessage' AND thread_id = :threadId AND deleted_at IS NULL ORDER BY created_at DESC LIMIT :limit;

getAgentLinkById: SELECT * FROM agent_links WHERE id = :id AND deleted_at IS NULL;

-- Companion narrow projection for agent_links. See
-- `getAgentEntityVectorClockById` for the rationale.
getAgentLinkVectorClockById:
  SELECT json_extract(serialized, '$.vectorClock') AS vector_clock
  FROM agent_links
  WHERE id = :id AND deleted_at IS NULL;

getAgentLinksByFromId: SELECT * FROM agent_links WHERE from_id = :fromId AND deleted_at IS NULL;

getAgentLinksByFromIdAndType: SELECT * FROM agent_links WHERE from_id = :fromId AND type = :type AND deleted_at IS NULL;

getAgentLinksByToId: SELECT * FROM agent_links WHERE to_id = :toId AND deleted_at IS NULL;

getAgentLinksByToIdAndType: SELECT * FROM agent_links WHERE to_id = :toId AND type = :type AND deleted_at IS NULL;

getWakeRunsByAgentId: SELECT * FROM wake_run_log WHERE agent_id = :agentId ORDER BY created_at DESC LIMIT :limit;

getWakeRunByKey: SELECT * FROM wake_run_log WHERE run_key = :runKey;

getWakeRunByThreadId: SELECT * FROM wake_run_log WHERE agent_id = :agentId AND thread_id = :threadId ORDER BY created_at DESC LIMIT 1;

getAllAgentIdentities: SELECT * FROM agent_entities WHERE type = 'agent' AND deleted_at IS NULL ORDER BY created_at DESC;

getPendingSagaOps: SELECT * FROM saga_log WHERE status = 'pending' ORDER BY created_at ASC;

deleteAgentEntities: DELETE FROM agent_entities WHERE agent_id = :agentId;

deleteAgentLinks: DELETE FROM agent_links WHERE from_id = :agentId OR to_id = :agentId OR from_id IN (SELECT id FROM agent_entities WHERE agent_id = :agentId) OR to_id IN (SELECT id FROM agent_entities WHERE agent_id = :agentId);

deleteAgentWakeRuns: DELETE FROM wake_run_log WHERE agent_id = :agentId;

deleteAgentSagaOps: DELETE FROM saga_log WHERE agent_id = :agentId;

getAllAgentTemplates: SELECT * FROM agent_entities WHERE type = 'agentTemplate' AND deleted_at IS NULL ORDER BY created_at DESC;

getAgentEntitiesByTypeGlobal: SELECT * FROM agent_entities WHERE type = :type AND deleted_at IS NULL ORDER BY updated_at DESC;

getAllAgentEntities: SELECT * FROM agent_entities WHERE deleted_at IS NULL ORDER BY created_at ASC;

getAgentEntitiesInInterval: SELECT * FROM agent_entities WHERE updated_at >= :start AND updated_at < :end ORDER BY updated_at ASC, id ASC LIMIT :limit OFFSET :offset;

countAgentEntitiesInInterval: SELECT COUNT(*) AS cnt FROM agent_entities WHERE updated_at >= :start AND updated_at < :end;

getAllAgentLinks: SELECT * FROM agent_links WHERE deleted_at IS NULL ORDER BY created_at ASC;

getAgentLinksInInterval: SELECT * FROM agent_links WHERE updated_at >= :start AND updated_at < :end ORDER BY updated_at ASC, id ASC LIMIT :limit OFFSET :offset;

countAgentLinksInInterval: SELECT COUNT(*) AS cnt FROM agent_links WHERE updated_at >= :start AND updated_at < :end;

getWakeRunsByTemplateId: SELECT * FROM wake_run_log WHERE template_id = :templateId ORDER BY created_at DESC LIMIT :limit;

countWakeRunsByTemplateId: SELECT COUNT(*) AS cnt FROM wake_run_log WHERE template_id = :templateId;

aggregateWakeRunMetricsByTemplateId: SELECT
  COUNT(CASE WHEN status = 'completed' THEN 1 END) AS success_count,
  COUNT(CASE WHEN status = 'failed' THEN 1 END) AS failure_count,
  CAST(SUM(CASE WHEN started_at IS NOT NULL AND completed_at IS NOT NULL AND completed_at - started_at > 0 THEN (completed_at - started_at) * 1000 ELSE 0 END) AS INT) AS duration_sum_ms,
  COUNT(CASE WHEN started_at IS NOT NULL AND completed_at IS NOT NULL AND completed_at - started_at > 0 THEN 1 END) AS duration_count,
  MIN(created_at) AS first_wake_at,
  MAX(created_at) AS last_wake_at
  FROM wake_run_log WHERE template_id = :templateId;

getWakeRunsByTemplateInWindow: SELECT * FROM wake_run_log WHERE template_id = :templateId AND created_at >= :since AND created_at <= :until ORDER BY created_at DESC;

getWakeRunsInWindow: SELECT * FROM wake_run_log WHERE created_at >= :since AND created_at <= :until ORDER BY created_at DESC;

getRecentReportsByTemplate: SELECT ae.* FROM agent_entities ae INNER JOIN agent_links al ON al.to_id = ae.agent_id AND al.type = 'template_assignment' WHERE al.from_id = :templateId AND ae.type = 'agentReport' AND ae.subtype = 'current' AND ae.deleted_at IS NULL AND al.deleted_at IS NULL ORDER BY ae.created_at DESC LIMIT :limit;

getRecentObservationsByTemplate: SELECT ae.* FROM agent_entities ae INNER JOIN agent_links al ON al.to_id = ae.agent_id AND al.type = 'template_assignment' WHERE al.from_id = :templateId AND ae.type = 'agentMessage' AND ae.subtype = 'observation' AND ae.deleted_at IS NULL AND al.deleted_at IS NULL ORDER BY ae.created_at DESC LIMIT :limit;

getEvolutionSessionsByTemplate: SELECT * FROM agent_entities WHERE agent_id = :templateId AND type = 'evolutionSession' AND deleted_at IS NULL ORDER BY created_at DESC LIMIT :limit;

getAllEvolutionSessions: SELECT es.** FROM agent_entities es INNER JOIN agent_entities tpl ON tpl.id = es.agent_id AND tpl.type = 'agentTemplate' AND tpl.deleted_at IS NULL WHERE es.type = 'evolutionSession' AND es.deleted_at IS NULL ORDER BY es.updated_at DESC;

getEvolutionNotesByTemplate: SELECT * FROM agent_entities WHERE agent_id = :templateId AND type = 'evolutionNote' AND deleted_at IS NULL ORDER BY created_at DESC LIMIT :limit;

countEntitiesChangedSinceForTemplate: SELECT COUNT(*) AS cnt FROM agent_entities ae INNER JOIN agent_links al ON al.to_id = ae.agent_id AND al.type = 'template_assignment' WHERE al.from_id = :templateId AND ae.updated_at > :since AND ae.deleted_at IS NULL AND al.deleted_at IS NULL;

-- Change set queries

getChangeSetsForAgent: SELECT * FROM agent_entities WHERE agent_id = :agentId AND type = 'changeSet' AND deleted_at IS NULL ORDER BY created_at DESC LIMIT :limit;

getPendingChangeSetsForAgent: SELECT * FROM agent_entities WHERE agent_id = :agentId AND type = 'changeSet' AND subtype IN ('pending', 'partiallyResolved') AND deleted_at IS NULL ORDER BY created_at DESC LIMIT :limit;

getRecentDecisionsForAgent: SELECT * FROM agent_entities WHERE agent_id = :agentId AND type = 'changeDecision' AND deleted_at IS NULL ORDER BY created_at DESC LIMIT :limit;

getRecentDecisionsByTemplate: SELECT ae.* FROM agent_entities ae INNER JOIN agent_links al ON al.to_id = ae.agent_id AND al.type = 'template_assignment' WHERE al.from_id = :templateId AND ae.type = 'changeDecision' AND ae.created_at >= :since AND ae.deleted_at IS NULL AND al.deleted_at IS NULL ORDER BY ae.created_at DESC LIMIT :limit;

getTokenUsageByAgentId: SELECT * FROM agent_entities WHERE agent_id = :agentId AND type = 'wakeTokenUsage' AND deleted_at IS NULL ORDER BY created_at DESC LIMIT :limit;

getTokenUsageByTemplateId: SELECT ae.* FROM agent_entities ae INNER JOIN agent_links al ON al.to_id = ae.agent_id AND al.type = 'template_assignment' WHERE al.from_id = :templateId AND ae.type = 'wakeTokenUsage' AND ae.deleted_at IS NULL AND al.deleted_at IS NULL ORDER BY ae.created_at DESC LIMIT :limit;

getTokenUsageByTemplateSince: SELECT ae.* FROM agent_entities ae INNER JOIN agent_links al ON al.to_id = ae.agent_id AND al.type = 'template_assignment' WHERE al.from_id = :templateId AND ae.type = 'wakeTokenUsage' AND ae.created_at >= :since AND ae.deleted_at IS NULL AND al.deleted_at IS NULL ORDER BY ae.created_at DESC;

sumTokenUsageByTemplate: SELECT
  CAST(COALESCE(SUM(json_extract(ae.serialized, '$.inputTokens')), 0) AS INT) AS total_input,
  CAST(COALESCE(SUM(json_extract(ae.serialized, '$.outputTokens')), 0) AS INT) AS total_output,
  CAST(COALESCE(SUM(json_extract(ae.serialized, '$.thoughtsTokens')), 0) AS INT) AS total_thoughts
  FROM agent_entities ae INNER JOIN agent_links al ON al.to_id = ae.agent_id AND al.type = 'template_assignment' WHERE al.from_id = :templateId AND ae.type = 'wakeTokenUsage' AND ae.deleted_at IS NULL AND al.deleted_at IS NULL;

sumTokenUsageByTemplateSince: SELECT
  CAST(COALESCE(SUM(json_extract(ae.serialized, '$.inputTokens')), 0) AS INT) AS total_input,
  CAST(COALESCE(SUM(json_extract(ae.serialized, '$.outputTokens')), 0) AS INT) AS total_output,
  CAST(COALESCE(SUM(json_extract(ae.serialized, '$.thoughtsTokens')), 0) AS INT) AS total_thoughts
  FROM agent_entities ae INNER JOIN agent_links al ON al.to_id = ae.agent_id AND al.type = 'template_assignment' WHERE al.from_id = :templateId AND ae.type = 'wakeTokenUsage' AND ae.created_at >= :since AND ae.deleted_at IS NULL AND al.deleted_at IS NULL;

getGlobalTokenUsageSince: SELECT * FROM agent_entities WHERE type = 'wakeTokenUsage' AND created_at >= :since AND deleted_at IS NULL ORDER BY created_at DESC;

getDueScheduledAgentStates: SELECT * FROM agent_entities WHERE type = 'agentState' AND deleted_at IS NULL AND json_extract(serialized, '$.scheduledWakeAt') IS NOT NULL AND json_extract(serialized, '$.scheduledWakeAt') <= :nowIso;

getAgentEntitiesWithNullVectorClock: SELECT * FROM agent_entities WHERE json_extract(serialized, '$.vectorClock') IS NULL ORDER BY created_at ASC;

countAgentEntitiesWithNullVectorClock: SELECT COUNT(*) AS cnt FROM agent_entities WHERE json_extract(serialized, '$.vectorClock') IS NULL;

getAgentLinksWithNullVectorClock: SELECT * FROM agent_links WHERE json_extract(serialized, '$.vectorClock') IS NULL ORDER BY created_at ASC;

countAgentLinksWithNullVectorClock: SELECT COUNT(*) AS cnt FROM agent_links WHERE json_extract(serialized, '$.vectorClock') IS NULL;

getAgentTaskLinkToIds: SELECT DISTINCT to_id FROM agent_links WHERE type = 'agent_task' AND deleted_at IS NULL;
